{
  "$schema": "https://docs.renovatebot.com/renovate-schema.json",
  "extends": [
    "config:base"
  ],
  "timezone": "Asia/Tokyo",
  "packageRules": [
    {
      "matchManagers": ["swift"],
      "fileMatch": ["^Package\\.swift$"]
    },
    {
      "matchManagers": ["swift"],
      "matchPaths": ["**/Package.resolved"],
      "enabled": false
    }
  ]
}
