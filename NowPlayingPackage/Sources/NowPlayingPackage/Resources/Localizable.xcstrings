    "1. Free tickets will be used first." : {
      "extractionState" : "manual",
      "localizations" : {
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "1. Free tickets will be used first."
          }
        },
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "1. 無料チケットから優先して消費されます。"
          }
        }
      }
    },
    "2. Posting tickets are only consumed when posting to X." : {
      "extractionState" : "manual",
      "localizations" : {
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "2. Posting tickets are only consumed when posting to X."
          }
        },
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "2. 投稿チケットはXへのポスト時のみ消費されます。"
          }
        }
      }
    },
    "3. Image uploads and text posts are treated as separate processes, and one ticket is consumed for each upon success." : {
      "extractionState" : "manual",
      "localizations" : {
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "3. Image uploads and text posts are treated as separate processes, and one ticket is consumed for each upon success."
          }
        },
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "3. 画像アップロードおよびテキスト投稿は、それぞれ独立した処理として扱われ、成功時に1枚ずつ消費されます。"
          }
        }
      }
    },
    "4. If the image upload succeeds but the text post fails, only one ticket for the image is consumed." : {
      "extractionState" : "manual",
      "localizations" : {
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "4. If the image upload succeeds but the text post fails, only one ticket for the image is consumed."
          }
        },
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "4. 画像アップロード成功後にテキスト投稿が失敗した場合、画像分の1枚のみ消費されます。"
          }
        }
      }
    },
    "5. If both the image and text succeed, a total of two tickets are consumed." : {
      "extractionState" : "manual",
      "localizations" : {
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "5. If both the image and text succeed, a total of two tickets are consumed."
          }
        },
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "5. 画像・テキストの両方が成功した場合は合計2枚消費されます。"
          }
        }
      }
    },
    "6. Tickets are only consumed for processes that succeed." : {
      "extractionState" : "manual",
      "localizations" : {
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "6. Tickets are only consumed for processes that succeed."
          }
        },
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "6. 各処理は「成功したもののみ」チケットが消費されます。"
          }
        }
      }
    },
